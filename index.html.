<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MegaBolão - Bilhetes Mega Millions 02</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#1e3a8a',
                        secondary: '#1e40af',
                        accent: '#fbbf24',
                        gold: '#f59e0b'
                    }
                }
            }
        }
    </script>
    <style>
        body {
            box-sizing: border-box;
        }
        .gradient-bg {
            background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
        }
        .card-shadow {
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
        .number-ball {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: white;
            background: linear-gradient(135deg, #f59e0b, #fbbf24);
        }
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .pulse {
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        #toast { 
            position: fixed; 
            right: 20px; 
            bottom: 20px; 
            background: #111827; 
            color: white; 
            padding: 12px 16px; 
            border-radius: 8px; 
            box-shadow: 0 6px 18px rgba(0,0,0,0.2); 
            display: none; 
            z-index: 9999; 
        }
        .pix-qr {
            background: #f3f4f6;
            border: 2px dashed #9ca3af;
            min-height: 200px;
        }
    </style>
</head>
<body class="bg-gray-50 min-h-full">
    <!-- Header -->
    <header class="gradient-bg text-white shadow-lg">
        <div class="container mx-auto px-4 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-2">
                    <div class="number-ball text-sm">🎯</div>
                    <h1 class="text-2xl font-bold">MegaBolão</h1>
                </div>
                <nav class="hidden md:flex space-x-6">
                    <a href="#" class="hover:text-accent transition-colors" onclick="showSection('hero')">Início</a>
                    <a href="#" class="hover:text-accent transition-colors" onclick="showSection('how')">Como Funciona</a>
                    <a href="#" class="hover:text-accent transition-colors" onclick="showSection('results')">Resultados</a>
                    <a href="#" class="hover:text-accent transition-colors" onclick="showSection('help')">Ajuda</a>
                </nav>
                <div class="flex space-x-2">
                    <button onclick="showLogin()" class="bg-white text-primary px-4 py-2 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
                        Entrar
                    </button>
                    <button onclick="showSignup()" class="bg-accent text-white px-4 py-2 rounded-lg font-semibold hover:bg-gold transition-colors">
                        Cadastrar
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8">
        <!-- Hero Section -->
        <section id="hero" class="text-center mb-12 fade-in">
            <h2 class="text-4xl font-bold text-gray-800 mb-4">
                Bilhetes Mega Millions 02
            </h2>
            <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
                Escolha seu pacote de bilhetes e participe do maior sorteio internacional!
            </p>
            
            <!-- Pacotes de Bilhetes -->
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto mb-8">
                <!-- 100 Bilhetes -->
                <div class="bg-white rounded-lg card-shadow p-6 border-2 border-transparent hover:border-primary transition-colors">
                    <div class="text-center">
                        <h3 class="text-xl font-bold text-gray-800 mb-2">100 Bilhetes</h3>
                        <div class="text-3xl font-bold text-primary mb-4">R$ 29,90</div>
                        <button onclick="showPayment(29.90, '100 Bilhetes')" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-secondary transition-colors w-full">
                            Comprar Agora
                        </button>
                    </div>
                </div>
                
                <!-- 250 Bilhetes -->
                <div class="bg-white rounded-lg card-shadow p-6 border-2 border-accent">
                    <div class="bg-accent text-white text-sm font-bold px-3 py-1 rounded-full inline-block mb-2">POPULAR</div>
                    <div class="text-center">
                        <h3 class="text-xl font-bold text-gray-800 mb-2">250 Bilhetes</h3>
                        <div class="text-3xl font-bold text-primary mb-4">R$ 49,90</div>
                        <button onclick="showPayment(49.90, '250 Bilhetes')" class="bg-accent text-white px-6 py-3 rounded-lg font-semibold hover:bg-gold transition-colors w-full">
                            Comprar Agora
                        </button>
                    </div>
                </div>
                
                <!-- 500 Bilhetes -->
                <div class="bg-white rounded-lg card-shadow p-6 border-2 border-transparent hover:border-primary transition-colors">
                    <div class="text-center">
                        <h3 class="text-xl font-bold text-gray-800 mb-2">500 Bilhetes</h3>
                        <div class="text-3xl font-bold text-primary mb-4">R$ 79,90</div>
                        <button onclick="showPayment(79.90, '500 Bilhetes')" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-secondary transition-colors w-full">
                            Comprar Agora
                        </button>
                    </div>
                </div>
                
                <!-- 1000 Bilhetes -->
                <div class="bg-white rounded-lg card-shadow p-6 border-2 border-green-500">
                    <div class="bg-green-500 text-white text-sm font-bold px-3 py-1 rounded-full inline-block mb-2">MELHOR VALOR</div>
                    <div class="text-center">
                        <h3 class="text-xl font-bold text-gray-800 mb-2">1.000 Bilhetes</h3>
                        <div class="text-3xl font-bold text-primary mb-4">R$ 129,90</div>
                        <button onclick="showPayment(129.90, '1.000 Bilhetes')" class="bg-green-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-green-700 transition-colors w-full">
                            Comprar Agora
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="flex justify-center">
                <button onclick="showSection('how')" class="border-2 border-primary text-primary px-8 py-3 rounded-lg font-semibold hover:bg-primary hover:text-white transition-colors">
                    Saiba Mais
                </button>
            </div>
        </section>

        <!-- Payment Section -->
        <section id="payment" class="hidden fade-in">
            <div class="max-w-md mx-auto bg-white rounded-lg card-shadow p-6">
                <div class="text-center mb-6">
                    <h3 class="text-2xl font-bold text-gray-800 mb-2">Pagamento PIX</h3>
                    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                        <strong>DEMONSTRAÇÃO:</strong> Este é um protótipo. Nenhum pagamento real será processado.
                    </div>
                    <div id="selectedPackage" class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4">
                        <p class="text-blue-800 font-semibold" id="packageInfo">100 Bilhetes Mega Millions 02</p>
                    </div>
                    <p class="text-gray-600">Valor: <span class="font-bold text-2xl text-primary" id="paymentAmount">R$ 29,90</span></p>
                </div>

                <!-- Email para envio dos bilhetes - PRIMEIRO -->
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
                    <h4 class="font-semibold text-yellow-800 mb-2">📧 Email para receber os bilhetes:</h4>
                    <input type="email" id="customerEmail" placeholder="Digite seu email aqui" class="w-full px-3 py-2 border border-yellow-300 rounded-lg focus:outline-none focus:border-yellow-500" required>
                    <p class="text-sm text-yellow-700 mt-2">Após o pagamento, enviaremos seu pack de bilhetes para este email.</p>
                </div>

                <!-- PIX QR Code Area -->
                <div class="pix-qr rounded-lg flex flex-col items-center justify-center p-6 mb-6">
                    <div class="text-6xl mb-4">📱</div>
                    <p class="text-gray-600 text-center">
                        QR Code PIX seria gerado aqui<br>
                        <small>(Funcionalidade de demonstração)</small>
                    </p>
                </div>

                <!-- PIX Key -->
                <div class="bg-gray-50 rounded-lg p-4 mb-6">
                    <h4 class="font-semibold text-gray-800 mb-2">Chave PIX:</h4>
                    <div class="flex items-center justify-between bg-white border rounded-lg p-3">
                        <span class="font-mono text-sm text-gray-700" id="pixKey">21524569-b504-4403-a964-6400708c5e4e</span>
                        <button onclick="copyPixKey()" class="bg-primary text-white px-3 py-1 rounded text-sm hover:bg-secondary transition-colors">
                            Copiar
                        </button>
                    </div>
                </div>

                <!-- Instructions -->
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
                    <h4 class="font-semibold text-blue-800 mb-2">Como pagar:</h4>
                    <ol class="text-sm text-blue-700 space-y-1">
                        <li>1. Digite seu email acima</li>
                        <li>2. Abra o app do seu banco</li>
                        <li>3. Escolha a opção PIX</li>
                        <li>4. Cole a chave PIX ou escaneie o QR Code</li>
                        <li>5. Confirme o valor</li>
                        <li>6. Finalize o pagamento</li>
                    </ol>
                </div>

                <!-- Payment Status -->
                <div id="paymentStatus" class="hidden bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
                    <div class="flex items-center">
                        <div class="text-green-500 text-xl mr-2">✅</div>
                        <div>
                            <h4 class="font-semibold text-green-800">Pagamento Confirmado!</h4>
                            <p class="text-sm text-green-700">Seus bilhetes foram registrados com sucesso.</p>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col gap-3">
                    <button onclick="simulatePayment()" class="bg-green-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-green-700 transition-colors">
                        Simular Pagamento Recebido
                    </button>
                    <button onclick="showSection('hero')" class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-semibold hover:bg-gray-50 transition-colors">
                        Voltar
                    </button>
                </div>
            </div>
        </section>

        <!-- How it Works Section -->
        <section id="how" class="hidden fade-in">
            <div class="max-w-4xl mx-auto">
                <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">Como Funciona</h2>
                <div class="grid md:grid-cols-3 gap-8">
                    <div class="text-center">
                        <div class="number-ball text-2xl mx-auto mb-4">1</div>
                        <h3 class="text-xl font-semibold mb-2">Escolha seu Pacote</h3>
                        <p class="text-gray-600">Selecione a quantidade de bilhetes que deseja comprar para o Mega Millions.</p>
                    </div>
                    <div class="text-center">
                        <div class="number-ball text-2xl mx-auto mb-4">2</div>
                        <h3 class="text-xl font-semibold mb-2">Pague via PIX</h3>
                        <p class="text-gray-600">Faça o pagamento de forma rápida e segura usando nossa chave PIX.</p>
                    </div>
                    <div class="text-center">
                        <div class="number-ball text-2xl mx-auto mb-4">3</div>
                        <h3 class="text-xl font-semibold mb-2">Acompanhe os Resultados</h3>
                        <p class="text-gray-600">Receba notificações e acompanhe os sorteios em tempo real.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Results Section -->
        <section id="results" class="hidden fade-in">
            <div class="max-w-4xl mx-auto">
                <h2 class="text-3xl font-bold text-center text-gray-800 mb-8">Últimos Resultados</h2>
                <div class="bg-white rounded-lg card-shadow p-6">
                    <div class="text-center mb-6">
                        <h3 class="text-xl font-semibold mb-2">Mega Millions - 15/01/2024</h3>
                        <div class="flex justify-center space-x-2 mb-4">
                            <span class="number-ball">07</span>
                            <span class="number-ball">29</span>
                            <span class="number-ball">60</span>
                            <span class="number-ball">63</span>
                            <span class="number-ball">66</span>
                            <span class="number-ball bg-red-500">15</span>
                        </div>
                        <p class="text-gray-600">Prêmio: $1.350.000.000</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Help Section -->
        <section id="help" class="hidden fade-in">
            <div class="max-w-4xl mx-auto">
                <h2 class="text-3xl font-bold text-center text-gray-800 mb-8">Ajuda</h2>
                <div class="bg-white rounded-lg card-shadow p-6">
                    <div class="space-y-6">
                        <div>
                            <h3 class="text-lg font-semibold mb-2">Como funciona o pagamento PIX?</h3>
                            <p class="text-gray-600">O PIX é instantâneo e seguro. Após o pagamento, seus bilhetes são confirmados automaticamente.</p>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold mb-2">Posso cancelar minha compra?</h3>
                            <p class="text-gray-600">Sim, você pode cancelar até 2 horas antes do sorteio e receber o reembolso.</p>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold mb-2">Como recebo meu prêmio?</h3>
                            <p class="text-gray-600">Os prêmios são distribuídos automaticamente via PIX para todos os ganhadores.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Login Modal -->
    <div id="loginModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white rounded-lg p-6 w-full max-w-md mx-4">
            <h3 class="text-xl font-bold mb-4">Entrar</h3>
            <form onsubmit="handleLogin(event)">
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Email</label>
                    <input type="email" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:border-primary" required>
                </div>
                <div class="mb-6">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Senha</label>
                    <input type="password" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:border-primary" required>
                </div>
                <div class="flex justify-between">
                    <button type="button" onclick="hideLogin()" class="px-4 py-2 text-gray-600 hover:text-gray-800">Cancelar</button>
                    <button type="submit" class="bg-primary text-white px-6 py-2 rounded-lg hover:bg-secondary">Entrar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Signup Modal -->
    <div id="signupModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white rounded-lg p-6 w-full max-w-md mx-4">
            <h3 class="text-xl font-bold mb-4">Cadastrar</h3>
            <form onsubmit="handleSignup(event)">
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Nome</label>
                    <input type="text" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:border-primary" required>
                </div>
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Email</label>
                    <input type="email" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:border-primary" required>
                </div>
                <div class="mb-6">
                    <label class="block text-gray-700 text-sm font-bold mb-2">Senha</label>
                    <input type="password" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:border-primary" required>
                </div>
                <div class="flex justify-between">
                    <button type="button" onclick="hideSignup()" class="px-4 py-2 text-gray-600 hover:text-gray-800">Cancelar</button>
                    <button type="submit" class="bg-primary text-white px-6 py-2 rounded-lg hover:bg-secondary">Cadastrar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Toast -->
    <div id="toast"></div>

    <script>
        // Navigation functions
        function showSection(sectionId) {
            const sections = ['hero', 'how', 'results', 'help', 'payment'];
            sections.forEach(id => {
                const element = document.getElementById(id);
                if (element) {
                    element.classList.add('hidden');
                }
            });
            
            const targetSection = document.getElementById(sectionId);
            if (targetSection) {
                targetSection.classList.remove('hidden');
            }
        }

        function showPayment(price = 29.90, packageName = '100 Bilhetes') {
            showSection('payment');
            document.getElementById('paymentAmount').textContent = `R$ ${price.toFixed(2).replace('.', ',')}`;
            document.getElementById('packageInfo').textContent = `${packageName} Mega Millions 02`;
            // Foca no campo de email quando abre a tela de pagamento
            setTimeout(() => {
                document.getElementById('customerEmail').focus();
            }, 100);
        }

        // Modal functions
        function showLogin() {
            document.getElementById('loginModal').classList.remove('hidden');
        }

        function hideLogin() {
            document.getElementById('loginModal').classList.add('hidden');
        }

        function showSignup() {
            document.getElementById('signupModal').classList.remove('hidden');
        }

        function hideSignup() {
            document.getElementById('signupModal').classList.add('hidden');
        }

        // Form handlers
        function handleLogin(event) {
            event.preventDefault();
            showToast('Login realizado com sucesso! (Demo)');
            hideLogin();
        }

        function handleSignup(event) {
            event.preventDefault();
            showToast('Cadastro realizado com sucesso! (Demo)');
            hideSignup();
        }

        // PIX functions
        function copyPixKey() {
            const pixKey = document.getElementById('pixKey').textContent;
            navigator.clipboard.writeText(pixKey).then(() => {
                showToast('Chave PIX copiada!');
            }).catch(() => {
                showToast('Erro ao copiar chave PIX');
            });
        }

        function simulatePayment() {
            const email = document.getElementById('customerEmail').value;
            
            if (!email) {
                showToast('Por favor, digite seu email primeiro!');
                document.getElementById('customerEmail').focus();
                return;
            }
            
            if (!email.includes('@')) {
                showToast('Por favor, digite um email válido!');
                document.getElementById('customerEmail').focus();
                return;
            }
            
            const statusDiv = document.getElementById('paymentStatus');
            const packageInfo = document.getElementById('packageInfo').textContent;
            
            // Atualiza a mensagem de confirmação com o email
            statusDiv.innerHTML = `
                <div class="flex items-center">
                    <div class="text-green-500 text-xl mr-2">✅</div>
                    <div>
                        <h4 class="font-semibold text-green-800">Pagamento Confirmado!</h4>
                        <p class="text-sm text-green-700">Seus bilhetes serão enviados para: <strong>${email}</strong></p>
                        <p class="text-sm text-green-600 mt-1">Pacote: ${packageInfo}</p>
                    </div>
                </div>
            `;
            
            statusDiv.classList.remove('hidden');
            showToast(`Bilhetes serão enviados para ${email}!`);
            
            // Scroll to status
            statusDiv.scrollIntoView({ behavior: 'smooth' });
        }

        // Toast function
        function showToast(message) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.style.display = 'block';
            
            setTimeout(() => {
                toast.style.display = 'none';
            }, 3000);
        }

        // Close modals when clicking outside
        document.addEventListener('click', function(event) {
            const loginModal = document.getElementById('loginModal');
            const signupModal = document.getElementById('signupModal');
            
            if (event.target === loginModal) {
                hideLogin();
            }
            if (event.target === signupModal) {
                hideSignup();
            }
        });
    </script>
